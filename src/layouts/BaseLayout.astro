---
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/sora/600.css';
import '@fontsource/sora/700.css';
import '../styles/global.css';
import { SITE } from '../config/site';
import { href } from '../utils/url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileBar from '../components/StickyMobileBar.astro';

interface Props {
  title: string;
  description: string;
  /** Page-level noindex (e.g. thank-you page), independent of the global preview noindex. */
  noindex?: boolean;
  /** Additional JSON-LD blocks (Service, BreadcrumbList, Article) rendered next to LocalBusiness. */
  extraSchema?: Record<string, unknown>[];
}

const { title, description, noindex = false, extraSchema = [] } = Astro.props;

// build.format 'file' leaves .html in pathname; canonical must match the clean served URL
const cleanPath = Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '');
const canonical = new URL(cleanPath || '/', Astro.site);
const previewNoindex = import.meta.env.PUBLIC_NOINDEX === 'true';
const analyticsOn = import.meta.env.PUBLIC_ANALYTICS === 'true';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.domain}/#business`,
  name: SITE.name,
  legalName: SITE.legalName,
  url: SITE.domain,
  telephone: '+48695946842',
  email: SITE.email,
  foundingDate: String(SITE.foundingYear),
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    postalCode: SITE.address.zip,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.region,
    addressCountry: 'PL',
  },
  geo: { '@type': 'GeoCoordinates', latitude: SITE.geo.lat, longitude: SITE.geo.lng },
  areaServed: 'PL',
  image: `${SITE.domain}/og-image.png`,
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '16:00',
  },
  ...(SITE.googleReviewsUrl ? { sameAs: [SITE.googleReviewsUrl] } : {}),
};

const ogImage = new URL(href('/og-image.png'), Astro.site);
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {(previewNoindex || noindex) && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href={href('/webclip.png')} />
    <link rel="apple-touch-icon" href={href('/webclip.png')} />
    <meta name="theme-color" content="#0a0f1a" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    {extraSchema.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)}

    {
      analyticsOn && (
        <>
          {/* Order matters: 1. Consent Mode v2 defaults -> 2. CookieYes -> 3. GTM -> 4. GSC */}
          <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            gtag('consent', 'default', {
              ad_storage: 'denied',
              ad_user_data: 'denied',
              ad_personalization: 'denied',
              analytics_storage: 'denied',
              functionality_storage: 'denied',
              personalization_storage: 'denied',
              security_storage: 'granted',
            });
          </script>
          <script
            is:inline
            id="cookieyes"
            type="text/javascript"
            src={`https://cdn-cookieyes.com/client_data/${SITE.cookieYesKey}/script.js`}
          />
          <script is:inline define:vars={{ gtmId: SITE.gtmId }}>
            (function (w, d, s, l, i) {
              w[l] = w[l] || [];
              w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
              var f = d.getElementsByTagName(s)[0],
                j = d.createElement(s),
                dl = l != 'dataLayer' ? '&l=' + l : '';
              j.async = true;
              j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
              f.parentNode.insertBefore(j, f);
            })(window, document, 'script', 'dataLayer', gtmId);
          </script>
          <meta name="google-site-verification" content={SITE.gscVerification} />
        </>
      )
    }
  </head>
  <body class="min-h-screen bg-white pb-16 md:pb-0">
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    {
      analyticsOn && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${SITE.gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }
    <Header />
    <slot />
    <Footer />
    <StickyMobileBar />

    <script>
      // Motion system "energia wraca": scroll reveal with stagger, self-drawing
      // timelines and stat counters. Hero is excluded (it has its own load animation).
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const hero = document.querySelector('header + section');
        const targets: Array<[Element, number]> = [];

        document.querySelectorAll('section > div.mx-auto').forEach((band) => {
          if (band.closest('section') === hero) return;
          if (!band.querySelector(':scope .grid, :scope ol, :scope ul')) {
            targets.push([band, 0]);
            return;
          }
          Array.from(band.children).forEach((child) => {
            const isCollection = child.classList.contains('grid') || child.tagName === 'OL' || child.tagName === 'UL';
            if (isCollection) {
              Array.from(child.children).forEach((item, i) => targets.push([item, 80 + i * 90]));
            } else {
              targets.push([child, 0]);
            }
          });
        });

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.1, rootMargin: '0px 0px -8% 0px' },
        );

        for (const [el, delay] of targets) {
          el.setAttribute('data-reveal', '');
          (el as HTMLElement).style.setProperty('--reveal-delay', `${delay}ms`);
          io.observe(el);
        }

        // Timelines (procedure on home, history on the about page) draw their line
        // top-down once they scroll into view; step markers ignite via CSS.
        const lineIo = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('line-drawn');
                lineIo.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15 },
        );
        document.querySelectorAll('ol[class*="border-l-2"]').forEach((ol) => lineIo.observe(ol));

        // Stat tiles like "80%" / "do 70%" count up when they appear.
        const counterIo = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              counterIo.unobserve(entry.target);
              const el = entry.target as HTMLElement;
              const raw = el.textContent?.trim() ?? '';
              const match = raw.match(/^(do\s*)?(\d+)(\s*%)$/);
              if (!match) continue;
              const prefix = match[1] ?? '';
              const total = Number(match[2]);
              const start = performance.now();
              const tick = (now: number) => {
                const progress = Math.min((now - start) / 900, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = `${prefix}${Math.round(total * eased)}%`;
                if (progress < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            }
          },
          { threshold: 0.4 },
        );
        document.querySelectorAll('p.font-display').forEach((p) => {
          if (/^(do\s*)?\d+\s*%$/.test(p.textContent?.trim() ?? '')) counterIo.observe(p);
        });
      }
    </script>
  </body>
</html>

---
import PhoneIcon from './icons/PhoneIcon.astro';
import { SITE } from '../config/site';
import { href } from '../utils/url';

interface Props {
  title?: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryTo?: string;
}

const {
  title = 'Zacznij od bezpłatnych pomiarów',
  subtitle = 'Przyjedziemy, zmierzymy każdą baterię i pokażemy, co realnie da się odzyskać.',
  primaryLabel = 'Zamów bezpłatny audyt',
  primaryTo = '/bezplatny-audyt',
} = Astro.props;
---

<section class="bg-ink-900">
  <div class="mx-auto max-w-6xl px-4 py-14 text-center">
    <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">{title}</h2>
    <p class="mx-auto mt-3 max-w-2xl text-gray-300">{subtitle}</p>
    <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={href(primaryTo)}
        class="w-full rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700 sm:w-auto"
      >
        {primaryLabel}
      </a>
      <a
        href={SITE.phoneHref}
        class="w-full rounded-lg border border-gray-500 px-6 py-3 font-semibold text-white transition hover:border-white sm:w-auto"
      >
        <PhoneIcon /> {SITE.phoneDisplay}
      </a>
    </div>
    <p class="mt-4 text-sm text-gray-400">
      Telefon odbiera technik, nie call center. W kilka minut usłyszysz, czy Twoja bateria rokuje.
    </p>
  </div>
</section>

---
import PhoneIcon from './icons/PhoneIcon.astro';
import { SITE } from '../config/site';
import { href } from '../utils/url';

const nav = [
  { label: 'Regeneracja', to: '/regeneracja-baterii-trakcyjnych' },
  { label: 'Serwis', to: '/serwis-baterii-trakcyjnych' },
  { label: 'Szkolenia', to: '/szkolenia-obsluga-baterii-trakcyjnych' },
  { label: 'Floty TIR', to: '/regeneracja-akumulatorow-ciezarowych' },
  { label: 'Realizacje', to: '/realizacje' },
  { label: 'Baza wiedzy', to: '/baza-wiedzy' },
  { label: 'Kontakt', to: '/kontakt' },
];
---

<header class="sticky top-0 z-40 bg-ink-900 text-white shadow-lg">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href={href('/')} class="flex shrink-0 items-center" aria-label="LIFT Baterie — strona główna">
      <img src={href('/logo-lift-baterie.svg')} alt="LIFT Baterie" class="h-8 w-auto" />
    </a>

    <nav class="hidden items-center gap-5 lg:flex" aria-label="Nawigacja główna">
      {nav.map((item) => (
        <a href={href(item.to)} class="text-sm font-medium text-gray-200 transition hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={SITE.phoneHref}
        class="hidden items-center gap-2 rounded-lg border border-brand-500 px-3 py-2 text-sm font-semibold text-brand-300 transition hover:bg-brand-600 hover:text-white sm:flex"
      >
        <PhoneIcon /> {SITE.phoneDisplay}
      </a>
      <a
        href={href('/bezplatny-audyt')}
        class="rounded-lg bg-brand-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-brand-700"
      >
        Bezpłatny audyt
      </a>
      <button
        id="nav-toggle"
        type="button"
        class="rounded-lg p-2 text-gray-200 hover:text-white lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Otwórz menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="hidden border-t border-ink-700 bg-ink-900 px-4 pb-4 lg:hidden" aria-label="Nawigacja mobilna">
    {nav.map((item) => (
      <a href={href(item.to)} class="block border-b border-ink-700 py-3 text-sm font-medium text-gray-200">
        {item.label}
      </a>
    ))}
    <a href={href('/o-nas')} class="block py-3 text-sm font-medium text-gray-200">O nas</a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

---
import PhoneIcon from '../components/icons/PhoneIcon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
import { href } from '../utils/url';
---

<BaseLayout
  title="Dziękujemy za zgłoszenie | LIFT Baterie"
  description="Twoje zgłoszenie dotarło. Oddzwonimy w ciągu 24 godzin w dni robocze."
  noindex
>
  <section class="mx-auto max-w-2xl px-4 py-24 text-center">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="mx-auto h-16 w-16 text-brand-600"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10" />
      <path d="m9 12 2 2 4-4" />
    </svg>
    <h1 class="mt-6 font-display text-3xl font-bold">Dziękujemy! Zgłoszenie dotarło.</h1>
    <p class="mt-4 text-gray-600">
      Oddzwonimy w ciągu 24 godzin w dni robocze. Jeśli sprawa jest pilna, zadzwoń teraz:
    </p>
    <a href={SITE.phoneHref} class="mt-6 inline-block rounded-lg bg-brand-600 px-8 py-3.5 font-bold text-white transition hover:bg-brand-700">
      <PhoneIcon /> {SITE.phoneDisplay}
    </a>
    <p class="mt-10">
      <a href={href('/')} class="text-sm font-semibold text-brand-600 hover:underline">← Wróć na stronę główną</a>
    </p>
  </section>
</BaseLayout>

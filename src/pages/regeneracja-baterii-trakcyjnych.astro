---
import TrustBar from '../components/TrustBar.astro';
import PhoneIcon from '../components/icons/PhoneIcon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FaqItem from '../components/FaqItem.astro';
import { SITE } from '../config/site';
import { href } from '../utils/url';
import { breadcrumbSchema, serviceSchema } from '../utils/schema';

const steps: { phase: string; items: { t: string; d: string }[] }[] = [
  {
    phase: 'Faza 1 — Diagnostyka (bezpłatny audyt)',
    items: [
      { t: 'Wywiad eksploatacyjny', d: 'Jak bateria pracowała i była ładowana, jakie są objawy. To ukierunkowuje pomiary.' },
      { t: 'Pomiar napięcia każdego ogniwa', d: 'Wyłapuje ogniwa odstające od pakietu i podejrzenia zwarć wewnętrznych.' },
      { t: 'Pomiar gęstości elektrolitu w każdym ogniwie', d: 'Gęstość pokazuje stopień naładowania i zasiarczenia, a rozrzut między ogniwami zdradza kondycję pakietu.' },
      { t: 'Oględziny i kontrola połączeń', d: 'Poziom elektrolitu, stan łączników międzyogniwowych, wtyków i skrzyni, ślady wycieków.' },
      { t: 'Test pojemności', d: 'Kontrolowane rozładowanie pokazuje, ile bateria naprawdę oddaje. To punkt odniesienia dla raportu.' },
      { t: 'Kwalifikacja: regenerować czy nie', d: 'Przy wypadniętej masie czynnej albo zwarciach odradzamy regenerację i proponujemy wymianę.' },
    ],
  },
  {
    phase: 'Faza 2 — Regeneracja na miejscu',
    items: [
      { t: 'Przygotowanie baterii', d: 'Czyszczenie, korekta poziomu elektrolitu wodą destylowaną, naprawa połączeń o podwyższonej rezystancji.' },
      { t: 'Desulfatacja impulsowa', d: 'Profesjonalny regenerator ogniw ołowiowych rozbija warstwę siarczanu ołowiu blokującą płyty, pod stałą kontrolą napięć i temperatury.' },
      { t: 'Cykle kontrolowanego ładowania i rozładowania', d: 'Odbudowują pojemność i uaktywniają odzyskaną powierzchnię płyt.' },
      { t: 'Ładowanie wyrównawcze pakietu', d: 'Wyrównuje parametry wszystkich ogniw, żeby najsłabsze przestało ciągnąć baterię w dół.' },
    ],
  },
  {
    phase: 'Faza 3 — Weryfikacja i raport',
    items: [
      { t: 'Test końcowy pojemności', d: 'Kryterium sukcesu to powrót powyżej 80% pojemności znamionowej, czyli progu, który normy branżowe przyjmują za granicę końca życia baterii. Bez zdanego testu nie zamykamy zlecenia.' },
      { t: 'Raport przed/po + zalecenia', d: 'Porównanie parametrów sprzed i po regeneracji oraz proste zalecenia dla operatorów, które utrwalają efekt.' },
    ],
  },
];

const costFactors = [
  { f: 'Napięcie i pojemność baterii', d: '24, 48 lub 80 V — im większy pakiet, tym więcej ogniw do przepracowania' },
  { f: 'Stopień zasiarczenia', d: 'wczesne skraca proces, wieloletnie wymaga dłuższych cykli' },
  { f: 'Liczba baterii w zleceniu', d: 'przy parku pracujemy rotacyjnie i koszt jednostkowy spada' },
  { f: 'Ewentualna wymiana ogniw', d: 'pojedyncze zwarte ogniwo wymieniamy zamiast dyskwalifikować całą baterię' },
  { f: 'Lokalizacja i terminy', d: 'dojazd w dowolne miejsce w Polsce, także nocą i w weekendy' },
];
---

<BaseLayout
  title="Regeneracja baterii trakcyjnych do wózków widłowych | LIFT Baterie"
  description="Regeneracja baterii trakcyjnych Pb, GEL i AGM u klienta, w całej Polsce. Do 70% taniej niż nowa bateria. Bezpłatny audyt i raport przed/po. Tel. 695 946 842"
  extraSchema={[
    serviceSchema({
      name: 'Regeneracja baterii trakcyjnych',
      description:
        'Mobilna regeneracja baterii trakcyjnych wózków widłowych (Pb, GEL, AGM): diagnostyka, desulfatacja, test pojemności i raport przed/po — u klienta, w całej Polsce.',
      path: '/regeneracja-baterii-trakcyjnych',
    }),
    breadcrumbSchema([
      { name: 'Start', path: '/' },
      { name: 'Regeneracja baterii trakcyjnych', path: '/regeneracja-baterii-trakcyjnych' },
    ]),
  ]}
>
  <section class="bg-ink-900 text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
      <h1 class="max-w-3xl font-display text-3xl font-bold leading-tight sm:text-4xl">
        Regeneracja baterii trakcyjnych do wózków widłowych — u Ciebie, bez przestojów
      </h1>
      <p class="mt-4 max-w-2xl text-gray-300">
        Przywracamy pojemność baterii kwasowych (Pb), żelowych (GEL) i AGM zamiast wymieniać je na nowe.
        Pracujemy na miejscu, w oknach serwisowych, a efekt potwierdzamy raportem przed/po.
      </p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a href="#audyt" class="rounded-lg bg-brand-600 px-6 py-3 text-center font-semibold transition hover:bg-brand-700">Zamów bezpłatny audyt</a>
        <a href={SITE.phoneHref} class="rounded-lg border border-gray-500 px-6 py-3 text-center font-semibold transition hover:border-white"><PhoneIcon /> {SITE.phoneDisplay}</a>
      </div>
    </div>
  </section>

  <TrustBar items={[`Od ${SITE.foundingYear} roku`, 'Cała Polska, dojazd do klienta', 'Do 70% taniej niż nowa bateria', 'Raport przed/po']} />

  <section class="mx-auto max-w-3xl px-4 py-14">
    <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold">Te objawy znasz z własnej hali?</h2>
    <ul class="mt-5 list-disc space-y-3 pl-5 text-gray-700 marker:text-brand-500">
      <li>Bateria <strong>nie trzyma pełnej zmiany</strong>: wózek gaśnie przed końcem pracy.</li>
      <li>Ładowanie trwa coraz dłużej, a efekt jest coraz krótszy.</li>
      <li>Ogniwa przegrzewają się podczas ładowania, rośnie zużycie wody destylowanej.</li>
      <li>Dostawca podpowiada „nowa bateria”, a to wydatek rzędu kilkudziesięciu tysięcy złotych.</li>
    </ul>
    <p class="mt-5 text-gray-700">
      W większości takich przypadków przyczyną jest <strong>zasiarczenie</strong>: odwracalny proces
      odkładania się siarczanu ołowiu na płytach ogniw. Regeneracja i
      <a href={href('/baza-wiedzy/odsiarczanie-baterii-trakcyjnej')} class="font-semibold text-brand-600 hover:underline">odsiarczanie (desulfatacja)</a>
      przywracają pojemność bez wymiany baterii. Pozostałe częste przyczyny opisaliśmy w artykule
      <a href={href('/baza-wiedzy/bateria-wozka-widlowego-szybko-sie-rozladowuje')} class="font-semibold text-brand-600 hover:underline">o 12 przyczynach słabej baterii</a>.
    </p>
  </section>

  <section class="bg-gray-50">
    <div class="mx-auto max-w-3xl px-4 py-14">
      <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold">Procedura LIFT — pełny przebieg regeneracji</h2>
      <p class="mt-3 text-gray-600">
        Każdy etap kończy się pomiarem, a o wyniku decyduje test pojemności. Cały proces odbywa się na
        miejscu i bateria nie wyjeżdża z zakładu.
      </p>
      {steps.map((phase) => (
        <div class="mt-8">
          <h3 class="font-display text-lg font-bold text-brand-700">{phase.phase}</h3>
          <ol class="mt-4 space-y-3">
            {phase.items.map((s, i) => (
              <li class="rounded-xl bg-white p-4 shadow-sm">
                <p class="font-semibold">{i + 1}. {s.t}</p>
                <p class="mt-1 text-sm text-gray-600">{s.d}</p>
              </li>
            ))}
          </ol>
        </div>
      ))}
      <p class="mt-6 text-sm text-gray-600">
        Krok po kroku, z czasami realizacji, opisaliśmy proces także w artykule
        <a href={href('/baza-wiedzy/jak-przebiega-regeneracja-baterii-trakcyjnej')} class="font-semibold text-brand-600 hover:underline">„Jak przebiega regeneracja baterii trakcyjnej”</a>.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-14">
    <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold">Regenerujemy baterie Pb, żelowe (GEL) i AGM</h2>
    <p class="mt-4 text-gray-700">
      Obsługujemy wszystkie popularne typy baterii trakcyjnych: klasyczne kwasowo-ołowiowe (PzS/PzB),
      żelowe oraz AGM, niezależnie od marki wózka i producenta baterii. Parametry procesu dobieramy do
      technologii ogniw. Pracujemy dla magazynów, zakładów produkcyjnych, centrów dystrybucyjnych
      i chłodni.
    </p>

    <h2 class="mt-10 border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold">Kiedy odradzamy regenerację</h2>
    <p class="mt-4 text-gray-700">
      Jeśli pomiary pokażą wypadniętą masę czynną, zwarcia ogniw albo uszkodzenia mechaniczne,
      regeneracja nie ma sensu. Usłyszysz to od nas przed wyceną, razem z rekomendacją wymiany.
      Pojedyncze słabe ogniwo w zdrowym pakiecie to z kolei wskazanie do
      <a href={href('/serwis-baterii-trakcyjnych')} class="font-semibold text-brand-600 hover:underline">wymiany ogniwa w ramach serwisu</a>,
      nie do pełnej regeneracji. Listę uszkodzeń nieodwracalnych zebraliśmy
      <a href={href('/baza-wiedzy/kiedy-bateria-nie-nadaje-sie-do-regeneracji')} class="font-semibold text-brand-600 hover:underline">w bazie wiedzy</a>.
      Dzięki temu płacisz tylko za usługi, które przynoszą efekt.
    </p>

    <div class="mt-8 rounded-2xl bg-brand-50 p-6 text-center">
      <p class="font-semibold text-ink-800">Nie wiesz, czy Twoja bateria się kwalifikuje?</p>
      <div class="mt-4 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="#audyt" class="rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Zamów bezpłatny audyt</a>
        <a href={SITE.phoneHref} class="rounded-lg border border-brand-300 px-6 py-3 font-semibold text-brand-700 transition hover:border-brand-600"><PhoneIcon /> {SITE.phoneDisplay}</a>
      </div>
    </div>

    <h2 class="mt-12 border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold">Czas realizacji: od doby do kilku dni</h2>
    <p class="mt-4 text-gray-700">
      Pojedyncza bateria zajmuje zwykle od jednej do kilku dób, zależnie od pojemności i stopnia
      zasiarczenia. Przy parku kilkunastu baterii pracujemy rotacyjnie, bateria po baterii, więc flota
      wózków cały czas ma zasilanie, a magazyn pracuje normalnie. Harmonogram ustalamy z góry.
    </p>

    <h2 class="mt-10 border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold">Co wpływa na cenę</h2>
    <p class="mt-4 text-gray-700">
      Konkretną wycenę przedstawiamy po audycie, bo rzetelnie da się ją policzyć dopiero po pomiarach. Jedno jest pewne: zasiarczenie utrwala się
      z każdym tygodniem pracy osłabionej baterii, więc im wcześniej pomiar, tym krótszy proces
      i niższy koszt. Na cenę składają się:
    </p>
    <ul class="mt-4 space-y-2 text-gray-700">
      {costFactors.map((c) => (
        <li class="rounded-xl border border-gray-200 p-4">
          <span class="font-semibold">{c.f}</span>: <span class="text-gray-600">{c.d}</span>
        </li>
      ))}
    </ul>
    <p class="mt-4 text-gray-700">
      Punkt odniesienia jest zawsze ten sam: regeneracja kosztuje <strong>do 70% mniej niż zakup nowej
      baterii</strong>, a efekt potwierdza test pojemności. Porównanie obu scenariuszy z kryteriami
      decyzji znajdziesz w artykule
      <a href={href('/baza-wiedzy/regeneracja-czy-nowa-bateria')} class="font-semibold text-brand-600 hover:underline">„Regeneracja czy zakup nowej baterii”</a>.
    </p>
  </section>

  <section class="bg-gray-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-center font-display text-2xl font-bold">Dlaczego regeneracja z LIFT Baterie</h2>
      <div class="mt-8 grid gap-6 text-center sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <p class="font-display text-3xl font-bold text-brand-600">80%</p>
          <p class="mt-2 text-sm text-gray-600">pojemności znamionowej: próg zaliczenia testu końcowego</p>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <p class="font-display text-3xl font-bold text-brand-600">1–3 doby</p>
          <p class="mt-2 text-sm text-gray-600">typowy czas regeneracji jednej baterii</p>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <p class="font-display text-3xl font-bold text-brand-600">24–80 V</p>
          <p class="mt-2 text-sm text-gray-600">pełen zakres napięć baterii trakcyjnych</p>
        </div>
      </div>
      <figure class="mx-auto mt-10 max-w-2xl rounded-2xl bg-white p-6 shadow-sm">
        <p class="text-sm font-bold text-brand-600">−40% kosztu w tej realizacji</p>
        <blockquote class="mt-2 text-sm text-gray-700">
          „Po audycie dostaliśmy jasną wycenę. Regeneracja obniżyła koszt o około 40% przy zachowaniu
          parametrów pracy baterii.”
        </blockquote>
        <figcaption class="mt-3 text-xs font-semibold text-gray-500">Firma logistyczna, Mazowsze</figcaption>
      </figure>
      <p class="mt-6 text-center">
        <a href={href('/realizacje')} class="text-sm font-semibold text-brand-600 hover:underline">Zobacz więcej realizacji →</a>
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-14">
    <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold">Pytania o regenerację</h2>
    <div class="mt-6">
      <FaqItem question="Czym jest odsiarczanie (desulfatacja) baterii trakcyjnej?">
        To proces rozbijania twardej warstwy siarczanu ołowiu, która blokuje płyty ogniw i odbiera
        baterii pojemność. Wykonujemy go impulsowo, pod kontrolą pomiarów. To serce całej regeneracji.
      </FaqItem>
      <FaqItem question="Ile trwa regeneracja baterii trakcyjnej?">
        Zależnie od stanu baterii i liczby sztuk: od jednej doby do kilku dni. Przy większych parkach
        pracujemy rotacyjnie, żeby flota wózków cały czas miała zasilanie.
      </FaqItem>
      <FaqItem question="Czy regeneracja działa na baterie żelowe i AGM?">
        Tak. Parametry procesu dobieramy do technologii baterii (Pb / GEL / AGM), a kwalifikację zawsze
        poprzedzają pomiary.
      </FaqItem>
      <FaqItem question="Czy dostanę gwarancję na efekt?">
        Efekt potwierdza test pojemności i raport przed/po. Warunki gwarancji na wykonaną usługę
        określamy w ofercie po audycie, zależnie od stanu i wieku baterii.
      </FaqItem>
      <FaqItem question="Co jeśli bateria nie nadaje się do regeneracji?">
        Dowiesz się tego zaraz po bezpłatnych pomiarach, razem z rekomendacją wymiany, zanim cokolwiek
        zapłacisz. Nie bierzemy zleceń, które nie rokują.
      </FaqItem>
    </div>
  </section>

  <section id="audyt" class="bg-ink-900">
    <div class="mx-auto max-w-2xl px-4 py-14">
      <h2 class="text-center font-display text-2xl font-bold text-white">Sprawdź, ile odzyska Twoja bateria</h2>
      <p class="mt-3 text-center text-gray-300">
        Bezpłatny audyt z pomiarami i konkretną rekomendacją, bez zobowiązań.
        Wolisz porozmawiać? <a href={SITE.phoneHref} class="font-bold text-brand-300"><PhoneIcon /> {SITE.phoneDisplay}</a>
      </p>
      <div class="mt-8 rounded-2xl bg-white p-6">
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>

---
import TrustBar from '../components/TrustBar.astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import FaqItem from '../components/FaqItem.astro';
import PhoneIcon from '../components/icons/PhoneIcon.astro';
import { SITE } from '../config/site';
import { href } from '../utils/url';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const services = [
  {
    title: 'Regeneracja baterii trakcyjnych',
    desc: 'Przywracamy pojemność baterii Pb, GEL i AGM bez wymiany na nowe. Diagnostyka, desulfatacja i test końcowy.',
    to: '/regeneracja-baterii-trakcyjnych',
  },
  {
    title: 'Serwis i przeglądy baterii',
    desc: 'Przeglądy co 1, 3 lub 6 miesięcy, naprawy i wymiana ogniw. Serwis przyjeżdża do baterii, nie odwrotnie.',
    to: '/serwis-baterii-trakcyjnych',
  },
  {
    title: 'Formatowanie i profilaktyka',
    desc: 'Coroczne formatowanie i ładowanie wyrównawcze zatrzymują zasiarczenie, zanim odbierze pojemność.',
    to: '/formatowanie-baterii-trakcyjnych',
  },
  {
    title: 'Szkolenia z eksploatacji',
    desc: 'Praktyczne szkolenia dla operatorów i utrzymania ruchu, na Waszych bateriach i prostownikach.',
    to: '/szkolenia-obsluga-baterii-trakcyjnych',
  },
];

const steps = [
  {
    t: 'Audyt i pomiary (0 zł)',
    d: 'Gęstość elektrolitu, napięcia ogniw, test pojemności. Rekomendacja z wyceną dla każdej baterii.',
  },
  {
    t: 'Regeneracja na miejscu',
    d: 'Desulfatacja i cykle kontrolowanego ładowania w Twoim zakładzie, w terminach poza szczytem hali.',
  },
  {
    t: 'Test końcowy',
    d: 'Kontrolowane rozładowanie potwierdza odzyskaną pojemność. Próg zaliczenia: 80% wartości znamionowej.',
  },
  {
    t: 'Raport i zalecenia',
    d: 'Parametry przed i po usłudze oraz wskazówki dla operatorów, które utrwalają efekt.',
  },
];

const cases = [
  {
    firm: 'Unimax, Kielce',
    quote: 'Prace zaplanowane w oknach serwisowych, produkcja nie stanęła. Wózki wróciły do pracy szybciej, niż zakładaliśmy.',
    tag: 'Produkcja nie stanęła',
  },
  {
    firm: 'Fabryka tworzyw sztucznych, Małopolska',
    quote: 'Realizacja rotacyjnie, bez wyłączania stref. Dziesięć sztuk zrobionych w trzy dni — magazyn działał normalnie.',
    tag: '10 baterii w 3 dni',
  },
  {
    firm: 'Magazyn e-commerce, Pomorskie',
    quote: 'Po usłudze dostaliśmy raport przed/po i proste zalecenia dla operatorów. Parametry trzymają do dziś.',
    tag: 'Parametry trzymają do dziś',
  },
];
---

<BaseLayout
  title="Regeneracja baterii przemysłowych — cała Polska | LIFT Baterie"
  description="Przywracamy sprawność baterii przemysłowych u klienta, w całej Polsce. Bezpłatny audyt, prace w oknach serwisowych, raport przed/po. Tel. 695 946 842."
>
  <!-- HERO -->
  <section class="bg-ink-900 text-white">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:py-28">
      <h1 class="max-w-3xl font-display text-3xl font-bold leading-tight sm:text-5xl">
        Regeneracja i serwis baterii przemysłowych — mobilnie, w całej Polsce
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-gray-300">
        Przywracamy sprawność baterii trakcyjnych i akumulatorów flot ciężarowych u Ciebie, w oknach
        serwisowych. Efekt potwierdzamy raportem przed/po.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href={href('/bezplatny-audyt')} class="rounded-lg bg-brand-600 px-6 py-3.5 text-center font-semibold transition hover:bg-brand-700">
          Zamów bezpłatny audyt
        </a>
        <a href={SITE.phoneHref} class="rounded-lg border border-gray-500 px-6 py-3.5 text-center font-semibold transition hover:border-white">
          <PhoneIcon /> Zadzwoń: {SITE.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <TrustBar />

  <!-- TWO PATHS -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      <a href={href('/regeneracja-baterii-trakcyjnych')} class="group rounded-2xl border border-gray-200 p-8 transition hover:-translate-y-0.5 hover:border-brand-500 hover:shadow-lg">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">Wózki widłowe</p>
        <h2 class="mt-2 font-display text-2xl font-bold">Baterie trakcyjne Pb / GEL / AGM</h2>
        <p class="mt-3 text-gray-600">
          Regeneracja, serwis, formatowanie i szkolenia. Oszczędność do 70% względem zakupu nowej baterii.
        </p>
        <p class="mt-4 font-semibold text-brand-600 group-hover:underline">Zobacz ofertę dla magazynów →</p>
      </a>
      <a href={href('/regeneracja-akumulatorow-ciezarowych')} class="group rounded-2xl border border-gray-200 p-8 transition hover:-translate-y-0.5 hover:border-brand-500 hover:shadow-lg">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">Floty transportowe</p>
        <h2 class="mt-2 font-display text-2xl font-bold">Akumulatory ciężarowe 12/24 V</h2>
        <p class="mt-3 text-gray-600">
          Audyt akumulatorów całej floty, diagnostyka i regeneracja na Twojej bazie. Mniej awarii zimą.
        </p>
        <p class="mt-4 font-semibold text-brand-600 group-hover:underline">Zobacz ofertę dla flot →</p>
      </a>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="bg-gray-50">
    <div class="mx-auto max-w-3xl px-4 py-16">
      <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold sm:text-3xl">
        Regeneracja baterii przemysłowych: odzyskaj sprawność zamiast kupować nowe
      </h2>
      <div class="mt-6 space-y-4 text-gray-700">
        <p>
          Baterie przemysłowe rzadko umierają ze starości. Najczęściej dobija je
          <strong>zasiarczenie</strong>: twarda warstwa siarczanu ołowiu, która narasta na płytach ogniw
          przy niepełnym ładowaniu, głębokich rozładowaniach i pracy w wysokich temperaturach. Bateria
          przestaje trzymać zmianę, wózek gaśnie przed końcem pracy, a ładowanie ciągnie się godzinami.
          W większości takich przypadków pojemność da się odzyskać.
        </p>
        <p>
          Prowadzimy <a href={href('/regeneracja-baterii-trakcyjnych')} class="font-semibold text-brand-600 hover:underline">regenerację baterii trakcyjnych</a>
          wózków widłowych (kwasowe Pb, żelowe GEL i AGM) oraz
          <a href={href('/regeneracja-akumulatorow-ciezarowych')} class="font-semibold text-brand-600 hover:underline">akumulatorów rozruchowych pojazdów ciężarowych</a>.
          Zaczynamy od pomiarów: gęstości elektrolitu, napięć ogniw i rzeczywistej pojemności. Jeśli
          bateria rokuje, przeprowadzamy desulfatację i cykle kontrolowanego ładowania, a wynik weryfikuje
          test pojemności. Jeśli nie rokuje, odradzamy i proponujemy wymianę. Płacisz za efekt, nie za próby.
        </p>
        <p>
          Sprawna bateria oszczędza dwa razy. Raz na zakupie, bo regeneracja kosztuje do 70% mniej niż
          nowa bateria. Drugi raz na prądzie: zasiarczone ogniwa mają wyższą rezystancję i przy każdym
          ładowaniu tracą energię na ciepło, więc <strong>po odsiarczeniu spada też rachunek za energię
          w prostowni</strong>.
        </p>
        <p>
          Cały proces odbywa się na miejscu, bez wysyłania baterii do serwisu. Dojeżdżamy do magazynów
          i baz w całej Polsce, a terminy planujemy tak, żeby hala pracowała normalnie: nocą, w weekend
          albo między zmianami. Park baterii utrzymujemy w formie przez
          <a href={href('/serwis-baterii-trakcyjnych')} class="font-semibold text-brand-600 hover:underline">przeglądy okresowe</a>
          i coroczne <a href={href('/formatowanie-baterii-trakcyjnych')} class="font-semibold text-brand-600 hover:underline">formatowanie baterii</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold sm:text-3xl">Nasze usługi</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {services.map((s) => (
        <a href={href(s.to)} class="group rounded-2xl border border-gray-200 p-6 transition hover:-translate-y-0.5 hover:border-brand-500 hover:shadow-lg">
          <h3 class="font-display text-lg font-bold">{s.title}</h3>
          <p class="mt-2 text-sm text-gray-600">{s.desc}</p>
          <p class="mt-3 text-sm font-semibold text-brand-600 group-hover:underline">Dowiedz się więcej →</p>
        </a>
      ))}
    </div>
  </section>

  <!-- PROCEDURE (timeline) -->
  <section class="bg-gray-50">
    <div class="mx-auto max-w-3xl px-4 py-16">
      <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold sm:text-3xl">
        Procedura LIFT: cztery kroki do sprawnej baterii
      </h2>
      <ol class="relative mt-10 space-y-10 border-l-2 border-brand-200 pl-8">
        {steps.map((s, i) => (
          <li class="relative">
            <span class="absolute -left-[49px] flex h-8 w-8 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">
              {i + 1}
            </span>
            <h3 class="font-semibold">{s.t}</h3>
            <p class="mt-1 text-sm text-gray-600">{s.d}</p>
          </li>
        ))}
      </ol>
      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={href('/bezplatny-audyt')} class="rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">
          Zacznij od bezpłatnego audytu
        </a>
        <a href={SITE.phoneHref} class="rounded-lg border border-gray-300 px-6 py-3 font-semibold text-ink-800 transition hover:border-ink-800">
          <PhoneIcon /> {SITE.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- CASES TEASER -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="flex items-end justify-between gap-4">
      <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold sm:text-3xl">Realizacje</h2>
      <a href={href('/realizacje')} class="text-sm font-semibold text-brand-600 hover:underline">Wszystkie realizacje →</a>
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {cases.map((c) => (
        <figure class="rounded-2xl border border-gray-200 p-6">
          <p class="text-sm font-bold text-brand-600">{c.tag}</p>
          <blockquote class="mt-3 text-sm text-gray-700">„{c.quote}”</blockquote>
          <figcaption class="mt-4 text-xs font-semibold text-gray-500">{c.firm}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- KNOWLEDGE BASE -->
  <section class="bg-gray-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="flex items-end justify-between gap-4">
        <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold sm:text-3xl">Baza wiedzy</h2>
        <a href={href('/baza-wiedzy')} class="text-sm font-semibold text-brand-600 hover:underline">Wszystkie artykuły →</a>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {latestPosts.map((post) => (
          <a
            href={href(`/baza-wiedzy/${post.id}`)}
            class="group rounded-2xl bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg"
          >
            <h3 class="font-display text-base font-bold group-hover:text-brand-700">{post.data.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{post.data.description}</p>
            <p class="mt-3 text-sm font-semibold text-brand-600 group-hover:underline">Czytaj →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h2 class="border-l-4 border-brand-500 pl-4 font-display text-2xl font-bold sm:text-3xl">
      Najczęściej zadawane pytania
    </h2>
    <div class="mt-6">
      <FaqItem question="Czy regeneracja zawsze się opłaca?">
        Nie. Zaczynamy od pomiarów i zdarza się, że odradzamy własną usługę: baterii z wypadniętą masą
        czynną albo zwartym ogniwem nie uratuje żadna technologia. W takiej sytuacji dostaniesz
        rekomendację wymiany zamiast kosztownych prób. Samo sprawdzenie nic nie kosztuje: pomiary
        wykonujemy w ramach bezpłatnego audytu.
      </FaqItem>
      <FaqItem question="Po czym poznać, że bateria nadaje się do regeneracji?">
        Typowe sygnały to skrócony czas pracy, dłuższe ładowanie i przegrzewające się ogniwa. Zwykle stoi
        za tym zasiarczenie, a ten proces jest odwracalny. Pewność dają dopiero pomiary.
      </FaqItem>
      <FaqItem question="Jak wygląda proces krok po kroku?">
        Diagnostyka, regeneracja, test końcowy i raport. Harmonogram ustalamy z góry, a prace prowadzimy
        poza godzinami szczytu magazynu.
      </FaqItem>
      <FaqItem question="Jakie baterie i branże obsługujecie?">
        Baterie trakcyjne Pb / GEL / AGM w wózkach widłowych oraz akumulatory rozruchowe 12/24 V we
        flotach ciężarowych. Pracujemy dla magazynów, produkcji, dystrybucji i transportu.
      </FaqItem>
      <FaqItem question="Ile to trwa i czy wstrzymacie mi magazyn?">
        Pojedyncza bateria to zwykle od jednej do kilku dób. Przy większych parkach działamy rotacyjnie,
        bateria po baterii, więc flota zachowuje pełną dyspozycyjność.
      </FaqItem>
      <FaqItem question="Ile to kosztuje?">
        Zależnie od typu, pojemności i stanu baterii oraz liczby sztuk. Konkretne kwoty poznasz po
        audycie; w typowym scenariuszu regeneracja wychodzi znacznie taniej niż zakup nowych baterii.
      </FaqItem>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

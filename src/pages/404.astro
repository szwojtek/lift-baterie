---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../utils/url';
---

<BaseLayout title="Strona nie istnieje | LIFT Baterie" description="Nie znaleziono strony." noindex>
  <section class="mx-auto max-w-2xl px-4 py-24 text-center">
    <p class="font-display text-6xl font-bold text-brand-600">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold">Ta strona nie istnieje</h1>
    <p class="mt-3 text-gray-600">Sprawdź adres albo przejdź do jednej z naszych usług:</p>
    <div class="mt-8 flex flex-col items-center gap-3">
      <a href={href('/regeneracja-baterii-trakcyjnych')} class="font-semibold text-brand-600 hover:underline">Regeneracja baterii trakcyjnych</a>
      <a href={href('/serwis-baterii-trakcyjnych')} class="font-semibold text-brand-600 hover:underline">Serwis baterii trakcyjnych</a>
      <a href={href('/bezplatny-audyt')} class="font-semibold text-brand-600 hover:underline">Bezpłatny audyt</a>
      <a href={href('/')} class="mt-4 rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Strona główna</a>
    </div>
  </section>
</BaseLayout>

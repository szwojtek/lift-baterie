---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const cases = [
  {
    firm: 'OSM Włoszczowa',
    tag: 'Stabilna praca w ruchu ciągłym',
    quote:
      'Zrobiliście audyt i formatowanie baterii w oknach serwisowych, bez wstrzymywania załadunków. Po wdrożeniu zaleceń wózki pracują stabilnie także w chłodniach.',
  },
  {
    firm: 'Unimax, Kielce',
    tag: 'Mniej przestojów już w pierwszym tygodniu',
    quote: 'Prace zaplanowane w oknach serwisowych, produkcja nie stanęła. Wózki wróciły do pracy szybciej, niż zakładaliśmy.',
  },
  {
    firm: 'Firma logistyczna, Mazowsze',
    tag: '40% taniej niż wymiana',
    quote: 'Po audycie dostaliśmy jasną wycenę. Regeneracja obniżyła koszt o około 40% przy zachowaniu parametrów pracy baterii.',
  },
  {
    firm: 'Fabryka tworzyw sztucznych, Małopolska',
    tag: '10 baterii w 3 dni',
    quote: 'Realizacja rotacyjnie, bez wyłączania stref. Dziesięć sztuk zrobionych w trzy dni — magazyn działał normalnie.',
  },
  {
    firm: 'Magazyn e-commerce, Pomorskie',
    tag: 'Raport i procedury utrzymały efekt',
    quote: 'Po usłudze dostaliśmy raport przed/po i proste zalecenia dla operatorów. Parametry trzymają do dziś.',
  },
];
---

<BaseLayout
  title="Realizacje — regeneracja i serwis baterii w praktyce | LIFT Baterie"
  description="Zobacz realizacje LIFT Baterie: regeneracja i formatowanie baterii trakcyjnych u klientów w całej Polsce — z liczbami i raportami przed/po."
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="font-display text-3xl font-bold sm:text-4xl">Realizacje</h1>
    <p class="mt-4 max-w-2xl text-gray-600">
      Każdą usługę kończymy raportem przed/po — poniżej wybrane wdrożenia. Sekcję sukcesywnie uzupełniamy
      o szczegółowe case studies z danymi pomiarowymi (Ah przed/po, % odzyskanej pojemności).
    </p>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {cases.map((c) => (
        <figure class="rounded-2xl border border-gray-200 p-6">
          <p class="text-sm font-bold text-brand-600">{c.tag}</p>
          <blockquote class="mt-3 text-gray-700">„{c.quote}"</blockquote>
          <figcaption class="mt-4 text-sm font-semibold text-gray-500">{c.firm}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <CtaBand title="Twoja hala może być następna" />
</BaseLayout>

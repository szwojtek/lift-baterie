---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { articleSchema, breadcrumbSchema } from '../../utils/schema';
import { href } from '../../utils/url';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const path = `/baza-wiedzy/${post.id}`;

const related = (await getCollection('blog'))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFormatted = post.data.pubDate.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${post.data.seoTitle ?? post.data.title} | LIFT Baterie`}
  description={post.data.description}
  extraSchema={[
    articleSchema({
      title: post.data.title,
      description: post.data.description,
      path,
      datePublished: post.data.pubDate.toISOString().slice(0, 10),
    }),
    breadcrumbSchema([
      { name: 'Start', path: '/' },
      { name: 'Baza wiedzy', path: '/baza-wiedzy' },
      { name: post.data.title, path },
    ]),
  ]}
>
  <article class="mx-auto max-w-3xl px-4 py-14">
    <nav class="text-sm text-gray-500" aria-label="Okruszki">
      <a href={href('/baza-wiedzy')} class="hover:text-brand-600">Baza wiedzy</a> / artykuł
    </nav>
    <h1 class="mt-3 font-display text-3xl font-bold leading-tight sm:text-4xl">{post.data.title}</h1>
    <p class="mt-3 text-sm text-gray-500">{dateFormatted} · LIFT Baterie</p>

    <div class="prose prose-gray mt-8 max-w-none prose-headings:font-display prose-a:text-brand-600">
      <Content />
    </div>

    <aside class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="font-display text-xl font-bold">Czytaj także</h2>
      <ul class="mt-4 grid gap-4 sm:grid-cols-3">
        {related.map((p) => (
          <li>
            <a
              href={href(`/baza-wiedzy/${p.id}`)}
              class="group block h-full rounded-2xl border border-gray-200 p-4 transition hover:border-brand-500 hover:shadow-md"
            >
              <p class="text-sm font-bold group-hover:text-brand-700">{p.data.title}</p>
              <p class="mt-2 text-xs font-semibold text-brand-600 group-hover:underline">Czytaj →</p>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  </article>

  <CtaBand />
</BaseLayout>

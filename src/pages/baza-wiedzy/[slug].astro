---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { articleSchema, breadcrumbSchema } from '../../utils/schema';
import { href } from '../../utils/url';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const path = `/baza-wiedzy/${post.id}`;

const dateFormatted = post.data.pubDate.toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${post.data.title} | LIFT Baterie`}
  description={post.data.description}
  extraSchema={[
    articleSchema({
      title: post.data.title,
      description: post.data.description,
      path,
      datePublished: post.data.pubDate.toISOString().slice(0, 10),
    }),
    breadcrumbSchema([
      { name: 'Start', path: '/' },
      { name: 'Baza wiedzy', path: '/baza-wiedzy' },
      { name: post.data.title, path },
    ]),
  ]}
>
  <article class="mx-auto max-w-3xl px-4 py-14">
    <nav class="text-sm text-gray-400" aria-label="Okruszki">
      <a href={href('/baza-wiedzy')} class="hover:text-brand-600">Baza wiedzy</a> / artykuł
    </nav>
    <h1 class="mt-3 font-display text-3xl font-bold leading-tight sm:text-4xl">{post.data.title}</h1>
    <p class="mt-3 text-sm text-gray-400">{dateFormatted} · LIFT Baterie</p>

    <div class="prose prose-gray mt-8 max-w-none prose-headings:font-display prose-a:text-brand-600">
      <Content />
    </div>
  </article>

  <CtaBand />
</BaseLayout>

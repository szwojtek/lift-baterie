---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { href } from '../../utils/url';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Baza wiedzy o bateriach trakcyjnych | LIFT Baterie"
  description="Praktyczna baza wiedzy o bateriach trakcyjnych i akumulatorach przemysłowych: eksploatacja, ładowanie, regeneracja, diagnostyka."
>
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="font-display text-3xl font-bold sm:text-4xl">Baza wiedzy</h1>
    <p class="mt-4 text-gray-600">
      Praktyczne poradniki o eksploatacji, diagnostyce i regeneracji baterii przemysłowych, pisane przez
      serwis, nie przez dział marketingu.
    </p>
    <ul class="mt-8 space-y-5">
      {posts.map((post) => (
        <li>
          <a
            href={href(`/baza-wiedzy/${post.id}`)}
            class="group block rounded-2xl border border-gray-200 p-6 transition hover:border-brand-500 hover:shadow-lg"
          >
            <h2 class="font-display text-lg font-bold group-hover:text-brand-700">{post.data.title}</h2>
            <p class="mt-2 text-sm text-gray-600">{post.data.description}</p>
            <p class="mt-3 text-sm font-semibold text-brand-600 group-hover:underline">Czytaj →</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <CtaBand />
</BaseLayout>
